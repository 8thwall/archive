licenses(["permissive"])  # MPL2

package(default_visibility = ["//visibility:public"])

cc_library(
    name = "qrcodegen",
    srcs = [
        "cpp/BitBuffer.cpp",
        "cpp/QrCode.cpp",
        "cpp/QrSegment.cpp",
    ],
    hdrs = [
        "cpp/BitBuffer.hpp",
        "cpp/QrCode.hpp",
        "cpp/QrSegment.hpp",
    ],
    includes = ["cpp"],
    visibility = ["//visibility:public"],
)
