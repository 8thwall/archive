diff --git a/c8/ecs/src/runtime/audio-buffer-sound.ts b/c8/ecs/src/runtime/audio-buffer-sound.ts
new file mode 100644
index 00000000000..f30ecaeafdf
--- /dev/null
+++ b/c8/ecs/src/runtime/audio-buffer-sound.ts
@@ -0,0 +1,128 @@
+import {DEFAULT_PITCH} from '../shared/audio-constants'
+import {assets} from './assets'
+import type {SoundSource} from './audio-sound'
+import type {AudioSettings} from './audio-sound-types'
+import type * as THREE_TYPES from './three-types'
+import THREE from './three'
+
+const createBufferAudio =
+(context: AudioContext, listener: THREE_TYPES.AudioListener, audio: AudioSettings): SoundSource => {
+  let audioNode: THREE_TYPES.PositionalAudio | THREE_TYPES.Audio
+  const controller = new AbortController()
+  let url: string | undefined
+  let buffer: AudioBuffer | null = null
+  let startTime = 0
+
+  audioNode = audio.positional
+    ? new THREE.PositionalAudio(listener)
+    : new THREE.Audio<GainNode>(listener)
+
+  const setAudioNode = (positional: boolean) => {
+    if (positional === !!(audioNode instanceof THREE.PositionalAudio)) {
+      return
+    }
+    audioNode = positional
+      ? new THREE.PositionalAudio(listener)
+      : new THREE.Audio<GainNode>(listener)
+    if (buffer) audioNode.setBuffer(buffer)
+  }
+
+  const loadSource = async (source: string, pitch?: number) => {
+    try {
+      const {signal} = controller
+      const asset = await assets.load({url: source})
+      if (signal.aborted) return
+      const data = await asset.data.arrayBuffer()
+      if (signal.aborted) return
+      context.decodeAudioData(data, (decodedBuffer) => {
+        audioNode.setBuffer(decodedBuffer)
+        audioNode.setPlaybackRate(pitch ?? DEFAULT_PITCH)
+        audioNode.setLoop(!!audio.loop)
+        audioNode.setVolume(audio.volume ?? 1)
+        url = source
+        if (!audio.paused) {
+          audioNode.play()
+        }
+        // update the internal buffer reference
+        buffer = decodedBuffer
+        startTime = context.currentTime
+      })
+    } catch (err) {
+      // eslint-disable-next-line no-console
+      console.warn('failed to load audio source', err)
+    }
+  }
+
+  const getCurrentTime = (): number => {
+    if (!buffer) return 0
+    if (!audioNode.isPlaying) return startTime + audioNode.offset
+
+    const total = (context.currentTime - startTime) - audioNode.offset * audioNode.getPlaybackRate()
+
+    return audioNode.loop ? total % buffer.duration : Math.min(total, buffer.duration)
+  }
+
+  const setCurrentTime = (time: number) => {
+    if (!buffer) return
+
+    const wasPlaying = audioNode.isPlaying
+    if (wasPlaying) audioNode.stop()
+
+    const startOffset = Math.max(0, Math.min(time, buffer.duration))
+
+    if (wasPlaying) {
+      audioNode.offset = startOffset
+      audioNode.play()
+      startTime = context.currentTime
+    }
+  }
+
+  // you play from the start, you play from the last offset
+  const playSourceNode = () => {
+    if (!buffer || audioNode.isPlaying) return
+    audioNode.play()
+  }
+
+  const pauseSourceNode = () => {
+    if (!buffer || !audioNode.isPlaying) return
+    audioNode.stop()
+  }
+
+  const setPlaybackRate = (pitch: number) => {
+    const elapsed = getCurrentTime()
+    audioNode.offset = elapsed
+    audioNode.setPlaybackRate(pitch)
+  }
+
+  loadSource(audio.url, audio.pitch)
+
+  return {
+    update: (config: AudioSettings) => {
+      if (config.url && config.url !== url) {
+        loadSource(config.url, config.pitch)
+      } else if (config.pitch) {
+        setPlaybackRate(config.pitch)
+      }
+
+      if (config.positional !== undefined) setAudioNode(config.positional)
+      if (config.loop !== undefined) audioNode.setLoop(config.loop)
+      if (config.volume !== undefined) audioNode.setVolume(config.volume)
+      if (config.paused) audioNode.pause()
+    },
+    getCurrentTime,
+    setCurrentTime,
+    pause: () => {
+      pauseSourceNode()
+    },
+    resume: () => {
+      playSourceNode()
+    },
+    destroy: () => {},
+    audioNode,
+    controller,
+  }
+}
+
+export {
+  createBufferAudio,
+}
diff --git a/c8/ecs/src/runtime/audio-element-sound.ts b/c8/ecs/src/runtime/audio-element-sound.ts
new file mode 100644
index 00000000000..3f8909e5806
--- /dev/null
+++ b/c8/ecs/src/runtime/audio-element-sound.ts
@@ -0,0 +1,88 @@
+import {DEFAULT_PITCH} from '../shared/audio-constants'
+import {assets} from './assets'
+import type {SoundSource} from './audio-sound'
+import type {AudioSettings} from './audio-sound-types'
+import type * as THREE_TYPES from './three-types'
+import THREE from './three'
+
+const createAudioElementSound =
+(context: AudioContext, listener: THREE_TYPES.AudioListener, audio: AudioSettings): SoundSource => {
+  const audioElement = new Audio()
+  audioElement.preload = 'auto'
+  audioElement.crossOrigin = 'anonymous'
+  const controller = new AbortController()
+
+  let audioNode: THREE_TYPES.PositionalAudio | THREE_TYPES.Audio
+  audioNode = audio.positional
+    ? new THREE.PositionalAudio(listener)
+    : new THREE.Audio<GainNode>(listener)
+
+  const setAudioNode = (positional: boolean) => {
+    if (positional === !!(audioNode instanceof THREE.PositionalAudio)) {
+      return
+    }
+
+    audioNode = positional
+      ? new THREE.PositionalAudio(listener)
+      : new THREE.Audio<GainNode>(listener)
+    audioNode.setMediaElementSource(audioElement)
+  }
+
+  const loadSource = async (source: string, pitch?: number) => {
+    try {
+      const {signal} = controller
+      const asset = await assets.load({url: source})
+      if (signal.aborted) {
+        return
+      }
+      audioElement.src = asset.localUrl
+      // playbackRate directly affects the pitch of the audio (sample rate conversion)
+      // https://developer.mozilla.org/en-US/docs/Web/API/HTMLMediaElement/playbackRate
+      // Need to set defaultPlaybackRate rather than playbackRate or else the playbackRate/pitch
+      // will be reset to default after load.
+      audioElement.defaultPlaybackRate = pitch ?? DEFAULT_PITCH
+      ;(audioElement as any).preservesPitch = false
+      audioElement.load()
+    } catch (err) {
+      // eslint-disable-next-line no-console
+      console.warn('failed to load audio source', err)
+    }
+  }
+
+  loadSource(audio.url, audio.pitch)
+
+  return {
+    update: (config: AudioSettings) => {
+      const sourceChanged = config.url && config.url !== audioElement.src
+      if (sourceChanged) {
+        loadSource(config.url, config.pitch)
+      } else if (config.pitch) {
+        audioElement.playbackRate = config.pitch
+      }
+
+      // handle audioNode type change
+      if (config.positional !== undefined) {
+        setAudioNode(config.positional)
+      }
+
+      audioElement.loop = config.loop ?? audioElement.loop
+      audioElement.volume = config.volume ?? audioElement.volume
+
+      if (config.paused) {
+        audioElement.pause()
+      }
+    },
+    getCurrentTime: () => audioElement.currentTime,
+    setCurrentTime: (time) => { audioElement.currentTime = time },
+    pause: () => { audioElement.pause() },
+    resume: () => { if (audioElement.paused) audioElement.play() },
+    destroy: () => {},
+    audioNode,
+    controller,
+    element: audioElement,
+  }
+}
+
+export {
+  createAudioElementSound,
+}
diff --git a/c8/ecs/src/runtime/audio-sound-types.ts b/c8/ecs/src/runtime/audio-sound-types.ts
new file mode 100644
index 00000000000..ae8933218b6
--- /dev/null
+++ b/c8/ecs/src/runtime/audio-sound-types.ts
@@ -0,0 +1,31 @@
+import type * as THREE_TYPES from './three-types'
+
+type AudioSettings = {
+  url: string
+  volume?: number
+  loop?: boolean
+  pitch?: number
+  paused?: boolean
+  positional?: boolean
+  refDistance?: number
+  rolloffFactor?: number
+  distanceModel?: string
+  maxDistance?: number
+}
+
+interface SoundSource {
+  update: (config: AudioSettings) => void
+  getCurrentTime: () => number
+  setCurrentTime: (time: number) => void
+  pause: () => void
+  resume: () => void
+  destroy: () => void
+  readonly audioNode: THREE_TYPES.Audio | THREE_TYPES.PositionalAudio
+  readonly controller: AbortController
+  readonly element?: HTMLMediaElement
+}
+
+export type {
+  AudioSettings,
+  SoundSource,
+}
diff --git a/c8/ecs/src/runtime/audio-sound.ts b/c8/ecs/src/runtime/audio-sound.ts
new file mode 100644
index 00000000000..9cc9dcbeb95
--- /dev/null
+++ b/c8/ecs/src/runtime/audio-sound.ts
@@ -0,0 +1,26 @@
+import {createBufferAudio} from './audio-buffer-sound'
+import {createAudioElementSound} from './audio-element-sound'
+import type {AudioSettings, SoundSource} from './audio-sound-types'
+import type * as THREE_TYPES from './three-types'
+
+const createSound = (
+  context: AudioContext, listener: THREE_TYPES.AudioListener, settings: AudioSettings
+): SoundSource => {
+  // note(alan): Not all platforms support AudioBuffer
+  // @ts-ignore
+  if (context.createBuffer) {
+    console.log('using buffer audio')
+    return createBufferAudio(context, listener, settings)
+  } else {
+    console.log('using element audio')
+    return createAudioElementSound(context, listener, settings)
+  }
+}
+
+export type {
+  SoundSource,
+}
+
+export {
+  createSound,
+}

