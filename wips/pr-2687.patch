+
+/*
+const tree = {
+  'undefined': ['a', 'b'],
+  'a': ['a1', 'a2', 'a3'],
+  'b': ['b1', 'b2'],
+  'a1': ['a1a', 'a1b'],
+  'a2': ['a2a'],
+  'a3': ['a3a'],
+  'a1b': ['a1b1', 'a1b2'],
+  'a1b2': ['a1b2a', 'a1b2b'],
+  'b1': [],
+  'b2': ['b2a', 'b2b'],
+  'b2b': ['b2b1', 'b2b2'],
+  'b2b2': ['b2b2a', 'b2b2b'],
+}
+
+a
+├── a1
+│   ├── a1a
+│   └── a1b
+│       ├── a1b1
+│       └── a1b2
+│           ├── a1b2a
+│           └── a1b2b
+├── a2
+│   └── a2a
+└── a3
+    └── a3a
+
+b
+├── b1
+└── b2
+    ├── b2a
+    └── b2b
+        ├── b2b1
+        └── b2b2
+            ├── b2b2a
+            └── b2b2b
+
+the divider of a1b2b should include: [a1b2, a1b]
+the divider of b2b2b should include: [b2b2, b2b, b2, b, undefined]
+
+so the rule is that, if you are the last child, you look for the parent,
+if the parent is also the last child, you look for the grandparent,
+and so on until you find a parent that is not the last child or hit the top level object.
+
+*/
