+
+const getEndDividers = (
+  id: string,
+  parentToChildren: Record<string, string[]>,
+  derivedScene: DerivedScene
+): string[] => {
+  const dividers: string[] = []
+  let currentId = id
+
+  // we only need the end dividers if you are the last in the siblings and have no children
+  const currParentId = derivedScene.getObject(currentId)?.parentId
+  const currSiblings = parentToChildren[currParentId] || []
+  if (parentToChildren[id]?.length > 0 || id !== currSiblings[currSiblings.length - 1]) {
+    return dividers
+  }
+
+  while (currentId) {
+    const parentId = derivedScene.getObject(currentId)?.parentId
+    const siblings = parentToChildren[parentId] || []
+    const isLastChild = siblings[siblings.length - 1] === currentId
+    if (isLastChild) {
+      dividers.push(parentId)
+      currentId = parentId
+    } else {
+      break
+    }
+  }
+  return dividers
 }
 
