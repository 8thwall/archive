@@ -0,0 +1,108 @@
+import React from 'react'
+
+import type {DerivedScene} from '../derive-scene'
+import {useDerivedScene} from '../derived-scene-context'
+import {useActiveSpace} from './active-space'
+import {useGitActiveClient} from '../../git/hooks/use-current-git'
+
+const SPACELESS_ID = 'spaceless-id'
+type FlattenedTreeNode = {
+  id: string
+  level: number
+  isSpace: boolean
+  spaceId?: string
+  parentId?: string
+  isLast?: boolean
+}
+
+const flattenTreeHierarchy = (
+  spaceIds: string[],
+  derivedScene: DerivedScene,
+  expanded: Record<string, boolean>,
+  activeSpaceId?: string
+) => {
+  const flattened: FlattenedTreeNode[] = []
+  const flattenNode = (
+    id: string, level: number, spaceId?: string, parentId?: string, isLast?: boolean
+  ) => {
+    flattened.push({id, level, isSpace: false, spaceId, parentId, isLast})
+    if (expanded[id]) {
+      const children = derivedScene.getChildren(id)
+      children.forEach((child, index) => {
+        flattenNode(child, level + 1, spaceId, id, index === children.length - 1)
+      })
+    }
+  }
+
+  spaceIds.forEach((spaceId) => {
+    if (spaceId && activeSpaceId && spaceId !== activeSpaceId) {
+      flattened.push({id: spaceId, level: 0, isSpace: true, spaceId, parentId: undefined})
+    }
+    if (expanded[spaceId]) {
+      const topLevelIds = derivedScene.getTopLevelObjectIds(spaceId)
+      topLevelIds.forEach((id, index) => {
+        flattenNode(id, 0, spaceId, spaceId, index === topLevelIds.length - 1)
+      })
+    }
+  })
+
+  if (activeSpaceId) {
+    const missingSpaceObjects = derivedScene.getTopLevelObjectIds(undefined)
+    if (missingSpaceObjects.length > 0) {
+      flattened.push({id: SPACELESS_ID, level: 0, isSpace: true, spaceId: undefined, parentId: undefined})
+      if (expanded[SPACELESS_ID]) {
+        missingSpaceObjects.forEach((id, index) => {
+          flattenNode(id, 0, undefined, undefined, index === missingSpaceObjects.length - 1)
+        })
+      }
+    }
+  }
+  return flattened
+}
+
+const useFlattenTreeHierarchy = (
+  spaceIds: string[]
+) => {
+  const derivedScene = useDerivedScene()
+  const activeSpace = useActiveSpace()
+  const activeClient = useGitActiveClient()
+
+  const allIds = derivedScene.getAllSceneObjects().map(e => e.id)
+    .concat(spaceIds)
+    .concat(SPACELESS_ID)
+
+  const [expanded, setExpanded] = React.useState<Record<string, boolean>>(
+    () => Object.fromEntries(allIds.map(id => [id, true]))
+  )
+
+  const [updateExpanded, setUpdateExpanded] = React.useState(false)
+  const prevIds = React.useRef<string[]>(undefined)
+
+  // this makes sure the hierarchy is expanded when the active client or active changes
+  React.useEffect(() => {
+    setUpdateExpanded(true)
+    prevIds.current = allIds
+  }, [activeClient, activeSpace?.id])
+
+  React.useEffect(() => {
+    if (updateExpanded && prevIds.current !== allIds) {
+      setExpanded(Object.fromEntries(allIds.map(id => [id, true])))
+      setUpdateExpanded(false)
+      prevIds.current = undefined
+    }
+  }, [updateExpanded, allIds])
+
+  // Flatten the tree for virtualization
+  const visibleNodes = React.useMemo(
+    () => flattenTreeHierarchy(spaceIds, derivedScene, expanded, activeSpace?.id),
+    [spaceIds, derivedScene, expanded, activeClient]
+  )
+
+  return {
+    expanded,
+    setExpanded,
+    visibleNodes,
+  }
+}
+
+export {useFlattenTreeHierarchy, SPACELESS_ID}
