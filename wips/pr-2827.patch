   element: HTMLElement,
-  event: PointerEvent
+  event: Pick<PointerEvent, 'clientX' | 'clientY'>
 ): ScreenPosition => {
   const rect = element.getBoundingClientRect()
   return ({
diff --git a/c8/ecs/src/runtime/raycast.ts b/c8/ecs/src/runtime/raycast.ts
index 653029990cb..13a68f44fe9 100644
--- a/c8/ecs/src/runtime/raycast.ts
+++ b/c8/ecs/src/runtime/raycast.ts
@@ -8,7 +8,9 @@ import {mat4} from './math/mat4'
 import {quat} from './math/quat'
 import THREE from './three'
 import {makeRaycastIntersections} from '../shared/custom-sorting'
+import {getProportionalPosition} from './pointer-events'
 
+const origin_ = new THREE.Vector2()
 const tempRayVector = vec3.zero()
 const tempRaycaster = new THREE.Raycaster()
 const tempMat4 = mat4.i()
@@ -59,7 +61,32 @@ const raycastFrom = (
   return raycast(world, tempTrs.t, tempRayVector, near, far)
 }
 
+const raycastScreenPosition = (
+  world: World,
+  screenPosition: [number, number],
+  near: number = 0,
+  far: number = Infinity
+) => {
+  const {activeCamera} = world.three
+  if (!activeCamera) {
+    console.warn('No active camera for raycasting from screen position')
+    return []
+  }
+  tempRaycaster.near = near
+  tempRaycaster.far = far
+  tempRaycaster.camera = activeCamera
+  const mockEvent = {clientX: screenPosition[0], clientY: screenPosition[1]}
+  const proportionalPosition = getProportionalPosition(world.three.renderer.domElement, mockEvent)
+  origin_.set(proportionalPosition.x * 2 - 1, -proportionalPosition.y * 2 + 1)
+  tempRaycaster.setFromCamera(origin_, activeCamera)
+
+  const intersectedObjects: Intersection[] = makeRaycastIntersections([])
+  tempRaycaster.intersectObjects(world.three.scene.children, true, intersectedObjects)
+  return processRaycastResults(intersectedObjects)
+}
+
 export {
   raycast,
   raycastFrom,
+  raycastScreenPosition,
 }
