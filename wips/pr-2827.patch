diff --git a/c8/ecs/src/runtime/raycast.ts b/c8/ecs/src/runtime/raycast.ts
index 8f08d031064..877555f8758 100644
--- a/c8/ecs/src/runtime/raycast.ts
+++ b/c8/ecs/src/runtime/raycast.ts
@@ -8,7 +8,8 @@ import {mat4} from './math/mat4'
 import {quat} from './math/quat'
 import THREE from './three'
 import {makeRaycastIntersections} from '../shared/custom-sorting'
-import {getProportionalPosition, ScreenPosition} from './pointer-events'
+import {getProportionalPosition, PointerPosition, ScreenPosition} from './pointer-events'
+import type {MousePosition} from './input-events'
 
 const origin_ = new THREE.Vector2()
 const tempRayVector = vec3.zero()
@@ -61,9 +62,15 @@ const raycastFrom = (
   return raycast(world, tempTrs.t, tempRayVector, near, far)
 }
 
+const isPointerPosition = (position: ScreenPosition | PointerPosition | MousePosition):
+  position is PointerPosition => 'clientX' in position && 'clientY' in position
+
+const isMousePosition = (position: ScreenPosition | PointerPosition | MousePosition):
+  position is MousePosition => Array.isArray(position)
+
 const raycastScreenPosition = (
   world: World,
-  screenPosition: ScreenPosition | [number, number],
+  position: ScreenPosition | PointerPosition | MousePosition,
   near: number = 0,
   far: number = Infinity
 ) => {
@@ -75,10 +82,16 @@ const raycastScreenPosition = (
   tempRaycaster.near = near
   tempRaycaster.far = far
   tempRaycaster.camera = activeCamera
-  const mockEvent = Array.isArray(screenPosition)
-    ? {clientX: screenPosition[0], clientY: screenPosition[1]}
-    : {clientX: screenPosition.x, clientY: screenPosition.y}
-  const proportionalPosition = getProportionalPosition(world.three.renderer.domElement, mockEvent)
+  let proportionalPosition: ScreenPosition
+  if (isPointerPosition(position)) {
+    proportionalPosition = getProportionalPosition(world.three.renderer.domElement, position)
+  } else if (isMousePosition(position)) {
+    const event = {clientX: position[0], clientY: position[1]}
+    proportionalPosition = getProportionalPosition(world.three.renderer.domElement, event)
+  } else {
+    proportionalPosition = position
+  }
+
   origin_.set(proportionalPosition.x * 2 - 1, -proportionalPosition.y * 2 + 1)
   tempRaycaster.setFromCamera(origin_, activeCamera)
 

