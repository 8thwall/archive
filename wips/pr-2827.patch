 type PointerId = PointerEvent['pointerId']
 
 interface ScreenTouchStartEvent {
@@ -93,7 +95,7 @@ type MaybeTargetedEvent = ScreenTouchStartEvent | ScreenTouchMoveEvent | ScreenT
 
 const getProportionalPosition = (
