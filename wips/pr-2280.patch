+const mergeDeletions = (
+  scene: DeepReadonly<SceneGraph>, objectId: string
+): string[] => {
+  const instances = descopeObjectId(objectId).slice(0, -1).reverse()
+  if (!instances || instances.length < 2) {
+    return []
+  }
+  const result: string[] = []
+
+  instances.forEach((instanceId) => {
+    const instance = scene.objects[instanceId]
+    if (instance?.instanceData?.children) {
+      const children = Object.entries(instance.instanceData.children)
+      children.forEach(([childId, childData]) => {
+        if (childData.deleted) {
+          result.push(childId)
+        }
+      })
+    }
+  })
+
+  console.log(`Merged deletions for ${objectId}:`, result)
+
+  return result
+}
