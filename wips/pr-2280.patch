   const getParentId = () => {
-    // case when parent is nested instance: [instance of T, instsance R of Q, sourceId]
-    const nestedParentId = descopeObjectId(id).slice(0, -1)
-
-    const isDirectChild = baseChildObject.parentId === rootInstance.instanceData?.instanceOf
-    if (isDirectChild) {
+    const isRootChild = baseChildObject.parentId === rootInstance.instanceData?.instanceOf
+    if (isRootChild) {
       return rootInstanceId
     }
+
+    // case when parent is nested instance: [instance of T, instsance R of Q, sourceId]
+    const instancePrefix = descopeObjectId(id).slice(0, -1)
+
+    // TODO, handle case where this is not size 2 or is not a direct child of another instance
     const isNestedPrefab = descopeObjectId(id).length > 2
