       : scopeObjectIds([rootInstanceId, baseChildObject.parentId])
   }
 
@@ -467,6 +469,34 @@ const getMergedInstanceChild = (
     return {id, parentId, ...baseChildRest}
   }
 
+  // Aggregegate the child overrides and deletions from nested prefabs
+
+  const aggregateOverrides = () => {
+    const instances = descopeObjectId(id).slice(0, -1).reverse()
+    const overrides = instances.map((instanceId) => {
+      const instance = scene.objects[instanceId]
+      if (instance && isPrefabInstance(instance) && instance.instanceData?.children[sourceId]) {
+        const childData = instance.instanceData.children[sourceId]
+        if (childData) {
+          return childData
+        }
+      }
+      return {}
+    })
+    const mergedOverrides = overrides.reduce((acc, curr) => {
+      Object.entries(curr).forEach(([key, value]) => {
+        if (value !== null && value) {
+          acc[key] = value
+        }
+      })
+      return acc
+    }, {} as Record<string, any>)
+
+    return mergedOverrides
+  }
+
+  console.log('agggregateOverrides', aggregateOverrides())
+
