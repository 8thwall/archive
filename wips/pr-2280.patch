diff --git a/reality/cloud/xrhome/test/nested-prefab-test.ts b/reality/cloud/xrhome/test/nested-prefab-test.ts
new file mode 100644
index 00000000000..0a8fc9ba6a2
--- /dev/null
+++ b/reality/cloud/xrhome/test/nested-prefab-test.ts
@@ -0,0 +1,421 @@
+import type {
+  BaseGraphObject,
+  GraphObject, PrefabInstanceChildren, SceneGraph,
+} from '@ecs/shared/scene-graph'
+import {assert} from 'chai'
+import { deriveScene } from '../src/client/studio/derive-scene'
+
+/* eslint quote-props: ["error", "as-needed"] */
+const makeObject = (id: string, extra?: Partial<GraphObject>): GraphObject => ({
+  id,
+  name: '<unset>',
+  position: [0, 0, 0],
+  rotation: [0, 0, 0, 1],
+  scale: [1, 1, 1],
+  geometry: null,
+  material: null,
+  components: {},
+  ...extra,
+})
+
+const makePrefab = (id: string, extra?: Partial<GraphObject>): BaseGraphObject => ({
+  id,
+  name: '<unset>',
+  position: [0, 0, 0],
+  rotation: [0, 0, 0, 1],
+  scale: [1, 1, 1],
+  geometry: null,
+  material: null,
+  prefab: true,
+  components: {},
+  ...extra,
+})
+
+const makeInstance = (
+  id: string, instanceOf: string, deletions?: {}, overrides?: Partial<GraphObject>,
+  children?: PrefabInstanceChildren
+): GraphObject => ({
+  id,
+  name: '<unset>',
+  position: [0, 0, 0],
+  rotation: [0, 0, 0, 1],
+  scale: [1, 1, 1],
+  components: {},
+  instanceData: {
+    instanceOf,
+    deletions:
+     deletions || {},
+    ...(children ? {children} : {}),
+  },
+  ...overrides,
+})
+
+describe('Nested Prefab Instances', () => {
+  it('should return all children of instance of B when scene is derived', () => {
+    // Prefab A with two children
+    const prefabA = makePrefab('prefabA')
+    const childA1 = makeObject('childA1', {parentId: 'prefabA', name: 'childA1'})
+    const childA2 = makeObject('childA2', {parentId: 'prefabA', name: 'childA2'})
+
+    // Prefab B with one child and an instance of prefabA
+    const prefabB = makePrefab('prefabB')
+    const childB1 = makeObject('childB1', {parentId: 'prefabB', name: 'childB1'})
+    const instanceOfAinB = makeInstance('instanceOfAinB', 'prefabA', {}, {parentId: 'prefabB'})
+    const instanceOfB = makeInstance('instanceOfB', 'prefabB')
+
+    const scene: SceneGraph = {
+      objects: {
+        prefabA,
+        childA1,
+        childA2,
+        prefabB,
+        childB1,
+        instanceOfAinB,
+        instanceOfB,
+      },
+      spaces: {},
+    }
+
+    const derivedScene = deriveScene(scene)
+
+    const childrenOfB = derivedScene.getChildren('instanceOfB')
+    assert.deepEqual(childrenOfB, ['instanceOfB/childB1', 'instanceOfB/instanceOfAinB'])
+
+    const childrenOfAinB = derivedScene.getChildren('instanceOfB/instanceOfAinB')
+    assert.deepEqual(childrenOfAinB,
+      ['instanceOfB/instanceOfAinB/childA1', 'instanceOfB/instanceOfAinB/childA2'])
+  })
+
+  it('should return all children of instance of C with three levels of nested prefabs', () => {
+  // Prefab A with one child
+    const prefabA = makePrefab('prefabA')
+    const childA1 = makeObject('childA1', {parentId: 'prefabA', name: 'childA1'})
+
+    // Prefab B with one child and an instance of prefabA
+    const prefabB = makePrefab('prefabB')
+    const childB1 = makeObject('childB1', {parentId: 'prefabB', name: 'childB1'})
+    const instanceOfAinB = makeInstance('instanceOfAinB', 'prefabA', {}, {parentId: 'prefabB'})
+
+    // Prefab C with one child and an instance of prefabB
+    const prefabC = makePrefab('prefabC')
+    const childC1 = makeObject('childC1', {parentId: 'prefabC', name: 'childC1'})
+    const instanceOfBinC = makeInstance('instanceOfBinC', 'prefabB', {}, {parentId: 'prefabC'})
+
+    // Instance of C
+    const instanceOfC = makeInstance('instanceOfC', 'prefabC')
+
+    const scene: SceneGraph = {
+      objects: {
+        prefabA,
+        childA1,
+        prefabB,
+        childB1,
+        instanceOfAinB,
+        prefabC,
+        childC1,
+        instanceOfBinC,
+        instanceOfC,
+      },
+      spaces: {},
+    }
+
+    const derivedScene = deriveScene(scene)
+
+    const childrenOfC = derivedScene.getChildren('instanceOfC')
+    assert.deepEqual(childrenOfC, ['instanceOfC/childC1', 'instanceOfC/instanceOfBinC'])
+
+    const childrenOfBinC = derivedScene.getChildren('instanceOfC/instanceOfBinC')
+    assert.deepEqual(childrenOfBinC, ['instanceOfC/instanceOfBinC/childB1',
+      'instanceOfC/instanceOfBinC/instanceOfAinB'])
+
+    const childrenOfAinBinC = derivedScene.getChildren('instanceOfC/instanceOfBinC/instanceOfAinB')
+    assert.deepEqual(childrenOfAinBinC, ['instanceOfC/instanceOfBinC/instanceOfAinB/childA1'])
+  })
+
+  it('should merge nested prefab instances with overrides correctly', () => {
+  // Prefab A with one child
+    const prefabA = makePrefab('prefabA')
+    const childA1 = makeObject('childA1', {
+      parentId: 'prefabA',
+      name: 'childA1',
+      geometry: {type: 'box', width: 1, height: 1, depth: 1},
+    })
+    // Prefab B with an instance of A and an override on childA1
+    const prefabB = makePrefab('prefabB')
+    const instanceOfAinB = makeInstance('instanceOfAinB', 'prefabA', {}, {parentId: 'prefabB'}, {
+      childA1: {
+        id: 'childA1',
+        deletions: {},
+        geometry: {type: 'sphere', radius: 2},
+        camera: {type: 'perspective', fov: 75},
+      },
+    })
+
+    const prefabC = makePrefab('prefabC')
+    const instanceOfBinC = makeInstance('instanceOfBinC', 'prefabB', {}, {parentId: 'prefabC'},
+      {
+        childA1: {
+          id: 'childA1',
+          deletions: {},
+          geometry: {type: 'cylinder', radius: 3, height: 5},
+          light: {type: 'point', color: '#ff0000', intensity: 1},
+        },
+      })
+
+    const instanceOfA = makeInstance('instanceOfA', 'prefabA')
+    const instanceOfB = makeInstance('instanceOfB', 'prefabB')
+    const instanceOfC = makeInstance('instanceOfC', 'prefabC')
+
+    const scene: SceneGraph = {
+      objects: {
+        prefabA,
+        childA1,
+        prefabB,
+        instanceOfAinB,
+        prefabC,
+        instanceOfBinC,
+        instanceOfA,
+        instanceOfB,
+        instanceOfC,
+      },
+      spaces: {},
+    }
+
+    const derivedScene = deriveScene(scene)
+    const mergedChildOfInstanceA = derivedScene.getObject('instanceOfA/childA1')
+    // Test prefab A instance without override
+    const expectedChildInstanceA = makeObject('instanceOfA/childA1', {
+      parentId: 'instanceOfA',
+      name: 'childA1',
+      geometry: {type: 'box', width: 1, height: 1, depth: 1},
+    }) as BaseGraphObject
+
+    assert.deepEqual(mergedChildOfInstanceA, expectedChildInstanceA,
+      'Failed to merge child of instance A correctly')
+
+    // Test prefab B instance with override
+    const mergedChildOfInstanceB = derivedScene.getObject('instanceOfB/instanceOfAinB/childA1')
+    assert.isDefined(mergedChildOfInstanceB)
+
+    const expectedChildInstanceB = makeObject('instanceOfB/instanceOfAinB/childA1', {
+      id: 'instanceOfB/instanceOfAinB/childA1',
+      parentId: 'instanceOfB/instanceOfAinB',
+      name: 'childA1',
+      geometry: {type: 'sphere', radius: 2},
+      camera: {type: 'perspective', fov: 75},
+    }) as BaseGraphObject
+
+    assert.deepEqual(mergedChildOfInstanceB, expectedChildInstanceB,
+      'Failed to merge child of instance B correctly')
+
+    // Test prefab C instance with override
+    const mergedChildOfInstanceC =
+  derivedScene.getObject('instanceOfC/instanceOfBinC/instanceOfAinB/childA1')
+    assert.isDefined(mergedChildOfInstanceC)
+
+    const expectedChildInstanceC = makeObject('instanceOfC/instanceOfBinC/instanceOfAinB/childA1', {
+      id: 'instanceOfC/instanceOfBinC/instanceOfAinB/childA1',
+      parentId: 'instanceOfC/instanceOfBinC/instanceOfAinB',
+      name: 'childA1',
+      geometry: {type: 'cylinder', radius: 3, height: 5},
+      camera: {type: 'perspective', fov: 75},
+      light: {type: 'point', color: '#ff0000', intensity: 1},
+    }) as BaseGraphObject
+
+    assert.deepEqual(mergedChildOfInstanceC, expectedChildInstanceC,
+      'Failed to merge child of instance C correctly')
+  })
+
+  it('should handle deletions correctly on nested prefab instances', () => {
+    // Prefab A with child that has multiple properties
+    const prefabA = makePrefab('prefabA')
+    const childA1 = makeObject('childA1', {
+      parentId: 'prefabA',
+      name: 'childA1',
+      geometry: {type: 'box', width: 1, height: 1, depth: 1},
+      material: {type: 'basic', color: '#ff0000'},
+    })
+
+    // Prefab B with instance of A and one of its own children
+    const prefabB = makePrefab('prefabB')
+    const childB1 = makeObject('childB1', {
+      parentId: 'prefabB',
+      name: 'childB1',
+      geometry: {type: 'sphere', radius: 1},
+      material: {type: 'basic', color: '#00ff00'},
+    })
+    const instanceOfAinB = makeInstance('instanceOfAinB', 'prefabA', {}, {parentId: 'prefabB'}, {
+      childA1: {
+        id: 'childA1',
+        deletions: {geometry: true},
+      },
+    })
+
+    // Instance of B with deletions on both its own child and nested child
+    const instanceOfB = makeInstance('instanceOfB', 'prefabB', {}, {}, {
+      childB1: {
+        id: 'childB1',
+        deletions: {material: true},
+      },
+      childA1: {
+        id: 'childA1',
+        deletions: {material: true},
+      },
+    })
+
+    const scene: SceneGraph = {
+      objects: {
+        prefabA,
+        childA1,
+        prefabB,
+        childB1,
+        instanceOfAinB,
+        instanceOfB,
+      },
+      spaces: {},
+    }
+
+    const derivedScene = deriveScene(scene)
+
+    // Test that child B1 has geometry but no material (deleted)
+    const mergedChildB1 = derivedScene.getObject('instanceOfB/childB1')
+    assert.isDefined(mergedChildB1)
+    assert.deepEqual(mergedChildB1.geometry, {type: 'sphere', radius: 1})
+    assert.isUndefined(mergedChildB1.material)
+
+    // Test that nested child A1 has no geometry (deleted in prefab B)
+    // and no material (deleted in instance of B)
+    const mergedChildA1 = derivedScene.getObject('instanceOfB/instanceOfAinB/childA1')
+    assert.isDefined(mergedChildA1)
+    assert.isUndefined(mergedChildA1.geometry)
+    assert.isUndefined(mergedChildA1.material)
+    assert.equal(mergedChildA1.name, 'childA1')
+  })
+
+  it('should handle deletion of entire child objects in nested prefabs', () => {
+    // Prefab A with two children
+    const prefabA = makePrefab('prefabA')
+    const childA1 = makeObject('childA1', {
+      parentId: 'prefabA',
+      name: 'childA1',
+      geometry: {type: 'box', width: 1, height: 1, depth: 1},
+    })
+    const childA2 = makeObject('childA2', {
+      parentId: 'prefabA',
+      name: 'childA2',
+      geometry: {type: 'sphere', radius: 1},
+    })
+
+    // Prefab B with instance of A and own child
+    const prefabB = makePrefab('prefabB')
+    const childB1 = makeObject('childB1', {
+      parentId: 'prefabB',
+      name: 'childB1',
+      geometry: {type: 'cylinder', radius: 1, height: 2},
+    })
+    const instanceOfAinB = makeInstance('instanceOfAinB', 'prefabA', {}, {parentId: 'prefabB'}, {
+      childA1: {
+        id: 'childA1',
+        deletions: {},
+      },
+      childA2: {
+        deleted: true,
+      },
+    })
+
+    // Instance of B that deletes its own child
+    const instanceOfB = makeInstance('instanceOfB', 'prefabB', {}, {}, {
+      childB1: {
+        deleted: true,
+      },
+    })
+
+    const scene: SceneGraph = {
+      objects: {
+        prefabA,
+        childA1,
+        childA2,
+        prefabB,
+        childB1,
+        instanceOfAinB,
+        instanceOfB,
+      },
+      spaces: {},
+    }
+
+    const derivedScene = deriveScene(scene)
+
+    // Should only have childA1 from nested prefab (childA2 deleted, childB1 deleted)
+    const childrenOfB = derivedScene.getChildren('instanceOfB')
+    assert.deepEqual(childrenOfB, ['instanceOfB/instanceOfAinB'])
+
+    const childrenOfNestedA = derivedScene.getChildren('instanceOfB/instanceOfAinB')
+    assert.deepEqual(childrenOfNestedA, ['instanceOfB/instanceOfAinB/childA1'])
+
+    // Verify the surviving child is properly merged
+    const mergedChildA1 = derivedScene.getObject('instanceOfB/instanceOfAinB/childA1')
+    assert.isDefined(mergedChildA1)
+    assert.equal(mergedChildA1.name, 'childA1')
+    assert.deepEqual(mergedChildA1.geometry, {type: 'box', width: 1, height: 1, depth: 1})
+  })
+
+  it('should handle component overrides correctly on nested prefab instances', () => {
+    const comp1Original = {id: 'comp1', name: 'comp1', parameters: {mass: 1.0}}
+    const comp1Override = {id: 'comp1', name: 'comp1', parameters: {mass: 2.0}}
+    const comp2Original = {id: 'comp2', name: 'comp2', parameters: {volume: 0.8}}
+    const comp2Override = {id: 'comp2', name: 'comp2', parameters: {volume: 0.5}}
+    const comp3Preserved = {id: 'comp3', name: 'comp3', parameters: {scale: 2.0}}
+    const comp4Original = {id: 'comp4', name: 'comp4', parameters: {intensity: 1.0}}
+    const comp4Override = {id: 'comp4', name: 'comp4', parameters: {intensity: 2.0}}
+    const compNew = {id: 'compNew', name: 'compNew', parameters: {value: 'B'}}
+    const compInstance = {id: 'compInstance', name: 'compInstance', parameters: {value: 'instance'}}
+
+    const prefabA = makePrefab('prefabA')
+    const childA1 = makeObject('childA1', {
+      parentId: 'prefabA',
+      components: {comp1: comp1Original, comp2: comp2Original, comp3: comp3Preserved},
+    })
+
+    const prefabB = makePrefab('prefabB')
+    const childB1 = makeObject('childB1', {
+      parentId: 'prefabB',
+      components: {comp4: comp4Original},
+    })
+    const instanceOfAinB = makeInstance('instanceOfAinB', 'prefabA', {}, {parentId: 'prefabB'}, {
+      childA1: {
+        id: 'childA1',
+        deletions: {},
+        components: {comp1: comp1Override, compNew},
+      },
+    })
+
+    const instanceOfB = makeInstance('instanceOfB', 'prefabB', {}, {}, {
+      childB1: {
+        id: 'childB1',
+        deletions: {},
+        components: {comp4: comp4Override},
+      },
+      childA1: {
+        id: 'childA1',
+        deletions: {},
+        components: {comp2: comp2Override, compInstance},
+      },
+    })
+
+    const scene: SceneGraph = {
+      objects: {prefabA, childA1, prefabB, childB1, instanceOfAinB, instanceOfB},
+      spaces: {},
+    }
+
+    const derivedScene = deriveScene(scene)
+    const mergedChildB1 = derivedScene.getObject('instanceOfB/childB1')
+    const mergedChildA1 = derivedScene.getObject('instanceOfB/instanceOfAinB/childA1')
+
+    assert.deepEqual(mergedChildB1.components.comp4, comp4Override)
+    assert.deepEqual(mergedChildA1.components.comp1, comp1Override)
+    assert.deepEqual(mergedChildA1.components.comp2, comp2Override)
+    assert.deepEqual(mergedChildA1.components.comp3, comp3Preserved)
+    assert.deepEqual(mergedChildA1.components.compNew, compNew)
+    assert.deepEqual(mergedChildA1.components.compInstance, compInstance)
+  })
+})
