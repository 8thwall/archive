@@ -64,6 +60,50 @@ const RESOURCE_MAP = {
   FONT: FONT_MAP,
 }
 
+type ResourceType = keyof typeof RESOURCE_MAP
+
+const createResourceManager = () => {
+  const defaultPrefix = 'https://cdn.8thwall.com'
+  let prefix = defaultPrefix
+
+  const prefixResource = <T extends string | Record<string, string>>(resource: T): T => {
+    if (typeof resource === 'string') {
+      return (prefix + resource) as T
+    } else if (typeof resource === 'object' && resource !== null) {
+      const result: Record<string, string> = {}
+      for (const [key, value] of Object.entries(resource)) {
+        result[key] = prefix + value
+      }
+      return result as T
+    }
+    throw new Error('Invalid resource format')
+  }
+
+  const loadResourceMap = <T extends ResourceType>(type: T): typeof RESOURCE_MAP[T] => {
+    const resourceMap = RESOURCE_MAP[type]
+    if (!resourceMap) {
+      throw new Error(`Resource type not found: ${type}`)
+    }
+    return Object.fromEntries(
+      Object.entries(resourceMap).map(([key, value]) => [key, prefixResource(value)])
+    ) as typeof RESOURCE_MAP[T]
+  }
+
+  // TODO(lreyna): Add method to load individual resources by name and type
+  // e.g. loadResource('FONT', 'Nunito')
+
+  const updateResourcePrefix = (newPrefix: string) => {
+    prefix = newPrefix
+  }
+
+  return {
+    loadResourceMap,
+    updateResourcePrefix,
+  }
+}
+
+const resourceManager = createResourceManager()
+
 export {
-  RESOURCE_MAP,
+  resourceManager,
 }

