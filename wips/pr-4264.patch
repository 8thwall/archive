-    backgroundColor: '#fff',
-  })
-  win.loadURL('desktop://dist/index.html')
-  registerWindowOpenHandler(win)
-  registerOnOpenUrlHandler(win)
-  return win
-}
-
 const ws = createStudioMcpWebsocketServer(MCP_WEBSOCKET_PORT)
 
 app.on('before-quit', () => {
@@ -105,14 +218,20 @@ app.whenReady()
     registerPreferencesHandler()
     maybeUpdateOnBeforeRequest()
     maybeInterceptAndReapplyDevCookie()
+    maybeInterceptOriginFor3rdPartyApi()
 
-    const win = createWindow()
+    let win: BrowserWindow
+    if (app.isPackaged) {
+      // Check for updates first, then create window
+      win = await checkForUpdates()
+      // Set up periodic update checks after initial startup
+      setupPeriodicUpdateCheck(win)
+    } else {
+      // In development, skip update check and create window directly
+      win = createWindow()
+    }
 
     win.webContents.on('did-finish-load', () => {
       setUpMainFileWatchPort(win)
     })
-
-    if (app.isPackaged) {
-      setupAutoUpdater(win)
-    }
   })
