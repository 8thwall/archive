 import {
@@ -20,17 +22,145 @@ import {setUpMainFileWatchPort} from './file-watch/ports'
 import {createStudioMcpWebsocketServer} from './studio-use/mcp-websocket-server'
 import {PREFERENCES_SCHEME, registerPreferencesHandler} from './preferences/protocol'
 import {maybeInterceptAndReapplyDevCookie} from './desktop-app/dev-cookie'
+import {maybeInterceptOriginFor3rdPartyApi} from './desktop-app/third-party-origin'
+import {loaderHtml} from './loader'
 
 const MCP_WEBSOCKET_PORT: number = parseInt(process.env.STUDIO_HUB_MCP_WEBSOCKET_PORT || '8080', 10)
 const UPDATE_CHECK_INTERVAL = 60 * 60 * 1000
 
-const setupAutoUpdater = (win: BrowserWindow) => {
-  autoUpdater.checkForUpdatesAndNotify()
+const createWindow = () => {
+  const win = new BrowserWindow({
+    width: 1600,
+    height: 1200,
+    minWidth: 900,
+    minHeight: 700,
+    webPreferences: {
+      preload: path.join(__dirname, 'preload.js'),
+    },
+  })
+  win.loadURL('desktop://dist/index.html')
+  registerWindowOpenHandler(win)
+  registerOnOpenUrlHandler(win)
+  return win
+}
+
+const createLoaderWindow = () => {
+  const loaderWin = new BrowserWindow({
+    width: 400,
+    height: 300,
+    frame: false,
+    alwaysOnTop: true,
+    center: true,
+    resizable: false,
+    webPreferences: {
+      nodeIntegration: true,
+      contextIsolation: false,
+    },
+  })
+
+  loaderWin.loadURL(`data:text/html;charset=utf-8,${encodeURIComponent(loaderHtml)}`)
+  return loaderWin
+}
+
+const checkForUpdates = async (): Promise<BrowserWindow> => new Promise((resolve) => {
+  let loaderWin: BrowserWindow | null = null
+  let updateCheckComplete = false
+
+  // Set up auto updater configuration
+  // autoUpdater.autoInstallOnAppQuit = false  // We'll handle restart manually
+
+  const createMainWindow = () => {
+    if (loaderWin) {
+      loaderWin.close()
+      loaderWin = null
+    }
+    const win = createWindow()
+    resolve(win)
+    return win
+  }
+
+  // Remove any existing listeners to prevent duplicates
+  autoUpdater.removeAllListeners('update-not-available')
+  autoUpdater.removeAllListeners('update-available')
+  autoUpdater.removeAllListeners('download-progress')
+  autoUpdater.removeAllListeners('update-downloaded')
+  autoUpdater.removeAllListeners('error')
+
+  // Handle when no update is available
+  const handleUpdateNotAvailable = () => {
+    log.info('No update available')
+    updateCheckComplete = true
+    createMainWindow()
+  }
+
+  // Handle when update is available - show loader
+  const handleUpdateAvailable = () => {
+    log.info('Update available, showing loader')
+    loaderWin = createLoaderWindow()
+    loaderWin.webContents.executeJavaScript(`
+        document.querySelector('.message').textContent = 'Downloading update...';
+      `)
+  }
+
+  // Handle download progress
+  const handleDownloadProgress = (progressObj: any) => {
+    if (loaderWin) {
+      log.info(`Download progress: ${progressObj.percent}%`)
+      const percent = Math.round(progressObj.percent)
+      loaderWin.webContents.executeJavaScript(`
+          document.querySelector('.message').textContent = 'Downloading update... ${percent}%';
+        `)
+    }
+  }
 
+  // Handle when update is downloaded - restart immediately
+  const handleUpdateDownloaded = () => {
+    log.info('Update downloaded, restarting app')
+    if (loaderWin) {
+      loaderWin.webContents.executeJavaScript(`
+          document.querySelector('.message').textContent = 'Update downloaded. Restarting...';
+        `)
+    }
+
+    // Wait a moment for the user to see the message, then restart
+    setTimeout(() => {
+      log.info('Quitting and installing update')
+      // autoUpdater.quitAndInstall()
+    }, 1000)
+  }
+
+  // Handle errors - proceed to main window
+  const handleError = (error: any) => {
+    log.error('Auto updater error:', error)
+    updateCheckComplete = true
+    createMainWindow()
+  }
+
+  // Set up one-time listeners for initial update check
+  autoUpdater.once('update-not-available', handleUpdateNotAvailable)
+  autoUpdater.once('update-available', handleUpdateAvailable)
+  autoUpdater.on('download-progress', handleDownloadProgress)
+  autoUpdater.once('update-downloaded', handleUpdateDownloaded)
+  autoUpdater.once('error', handleError)
+
+  // Start the update check
+  autoUpdater.checkForUpdates()
+
+  // Fallback timeout in case update check hangs
+  setTimeout(() => {
+    if (!updateCheckComplete && !loaderWin) {
+      updateCheckComplete = true
+      createMainWindow()
+    }
+  }, 10000)  // 10 second timeout
+})
+
+const setupPeriodicUpdateCheck = (win: BrowserWindow) => {
   setInterval(() => {
     autoUpdater.checkForUpdatesAndNotify()
   }, UPDATE_CHECK_INTERVAL)
 
+  // Handle periodic updates with user confirmation
   autoUpdater.on('update-downloaded', () => {
     const result = dialog.showMessageBoxSync(win, {
       type: 'info',
@@ -66,23 +196,6 @@ try {
 
 app.commandLine.appendSwitch('ignore-certificate-errors')
 
