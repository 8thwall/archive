diff --git a/reality/cloud/xrhome/src/client/studio/embed-video-buffer.ts b/reality/cloud/xrhome/src/client/studio/embed-video-buffer.ts
new file mode 100644
index 00000000000..770ec7cb949
--- /dev/null
+++ b/reality/cloud/xrhome/src/client/studio/embed-video-buffer.ts
@@ -0,0 +1,130 @@
+import type {Document} from '@gltf-transform/core'
+import {Object3D, Mesh} from 'three'
+import type {GLTF} from 'three-stdlib'
+
+import type {EmbeddedVideos} from '@ecs/runtime/video-types'
+import {VIDEO_ACCESSOR_NAME} from '@ecs/shared/video-constants'
+
+const getArrayBufferFromVideo = async (videoUrl: string): Promise<ArrayBuffer> => {
+  try {
+    const response = await fetch(videoUrl)
+    if (!response.ok) {
+      throw new Error(`Failed to fetch video to convert to data URL: ${response.status}`)
+    }
+    return response.arrayBuffer()
+  } catch (error) {
+    throw new Error(`Failed to fetch video to convert to data URL: ${error}`)
+  }
+}
+
+const getMimeTypeFromBuffer = (arrayBuffer: ArrayBuffer): string | undefined => {
+  const bytes = new Uint8Array(arrayBuffer, 0, 8)
+  if (bytes[4] === 0x66 && bytes[5] === 0x74 && bytes[6] === 0x79 && bytes[7] === 0x70) {
+    return 'video/mp4'
+  }
+  if (bytes[0] === 0x1A && bytes[1] === 0x45 && bytes[2] === 0xDF && bytes[3] === 0xA3) {
+    return 'video/webm'
+  }
+  return undefined
+}
+
+const extractVideosToEmbed = (
+  scene: Object3D, existingEmbeddedVideos: EmbeddedVideos | undefined,
+  videosToEmbed: EmbeddedVideos, videoArrayBuffers: Record<string, ArrayBuffer>,
+  existingVideoBuffer: ArrayBuffer | undefined
+): number => {
+  const textureKeys = [
+    'map', 'alphaMap', 'roughnessMap', 'metalnessMap', 'normalMap', 'emissiveMap',
+  ]
+
+  scene.traverse((object: Object3D) => {
+    if (object instanceof Mesh && object.material) {
+      textureKeys.forEach((textureKey) => {
+        const videoData = object.material.userData?.videos
+        if (!videoData || !videoData?.[textureKey]) {
+          return
+        }
+        const videoDataByTexture = videoData[textureKey]
+        const {url} = videoDataByTexture
+        const existingData = existingEmbeddedVideos?.[url]
+        if (!videosToEmbed[url]) {
+          videosToEmbed[url] = {
+            offset: 0,  // Will be calculated and set later once all video data is collected
+            length: existingData ? existingData.length : videoDataByTexture.buffer.byteLength,
+            mimeType: existingData
+              ? existingData.mimeType
+              : getMimeTypeFromBuffer(videoDataByTexture.buffer),
+          }
+          videoArrayBuffers[url] = (existingData && existingVideoBuffer)
+            ? existingVideoBuffer.slice(
+              existingData.offset,
+              existingData.offset + existingData.length
+            )
+            : videoDataByTexture.buffer
+        }
+      })
+    }
+  })
+
+  let size = 0
+  Object.values(videosToEmbed).forEach(({length}) => { size += length })
+  return size
+}
+
+const embedVideoBuffers = async (glbDocument: Document, scene: Object3D, gltf: GLTF) => {
+  const root = glbDocument.getRoot()
+  const buffers = root.listBuffers()
+  if (!buffers.length) {
+    throw new Error('Failed to embed video to 3D asset - no buffers found in .glb to embed')
+  }
+  const mainBuffer = buffers[0]
+
+  const {parser, userData} = gltf
+
+  // Find existing accessor and video buffer from the original .glb
+  const existingAccessorIndex = parser.json.accessors.findIndex(
+    acc => acc.name === VIDEO_ACCESSOR_NAME
+  )
+  const existingAccessor = existingAccessorIndex > -1
+    ? await parser.getDependency('accessor', existingAccessorIndex)
+    : null
+  const existingEmbeddedVideos = userData?.embeddedVideos as EmbeddedVideos | undefined
+  const existingVideoBuffer = existingAccessor?.array.buffer.slice(
+    existingAccessor?.array.byteOffset,
+    existingAccessor?.array.byteOffset + existingAccessor?.array.byteLength
+  )
+
+  const videosToEmbed: EmbeddedVideos = {}
+  const arrayBuffersToEmbed: Record<string, ArrayBuffer> = {}
+
+  const totalSize = extractVideosToEmbed(scene, existingEmbeddedVideos, videosToEmbed,
+    arrayBuffersToEmbed, existingVideoBuffer)
+
+  if (totalSize) {
+    const videoBuffer = new ArrayBuffer(totalSize)
+    const videoBufferView = new Uint8Array(videoBuffer)
+
+    let offset = 0
+    Object.entries(videosToEmbed).forEach(([url, embeddedData]) => {
+      embeddedData.offset = offset
+      const bufferView = new Uint8Array(arrayBuffersToEmbed[url])
+      videoBufferView.set(bufferView, offset)
+      offset += embeddedData.length
+    })
+
+    // Create new accessor and embed new video buffer into this new glTF document for exporting
+    const accessor = glbDocument.createAccessor(VIDEO_ACCESSOR_NAME)
+    accessor.setArray(videoBufferView)
+    accessor.setType('SCALAR')
+    accessor.setBuffer(mainBuffer)
+
+    root.setExtras({...root.getExtras(), embeddedVideos: videosToEmbed})
+  } else {
+    delete root.getExtras()?.embeddedVideos
+  }
+}
+
+export {
+  embedVideoBuffers,
+  getArrayBufferFromVideo,
+}

