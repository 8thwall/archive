+    let win: BrowserWindow
+    if (app.isPackaged) {
+      // Check for updates first, then create window
+      win = await checkForUpdates()
+      // Set up periodic update checks after initial startup
+      setupPeriodicUpdateCheck(win)
+    } else {
+      // In development, skip update check and create window directly
+      win = createWindow()
+    }
 
     win.webContents.on('did-finish-load', () => {
       setUpMainFileWatchPort(win)
     })
-
