{
  "name": "hellomcp",
  "version": "0.1.0",
  "description": "MCP server for interacting with Studio",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start:mcp": "DEBUG=1 npx @modelcontextprotocol/inspector tsx src/index.ts",
    "start:debug": "DEBUG=1 npx @modelcontextprotocol/inspector tsx src/debug-server.ts",
    "generate:ecs-schemas": "npx tsx scripts/generate-ecs-schemas.ts",
    "print-schema": "npx tsx scripts/print-schema.ts"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "access": "public",
  "dependencies": {
    "@langchain/aws": "^0.1.7",
    "@langchain/core": "^0.3.43",
    "@langchain/langgraph": "^0.2.63",
    "@modelcontextprotocol/sdk": "^1.8.0",
    "dotenv": "^16.5.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@ast-grep/napi": "^0.37.0",
    "@types/node": "^22.13.13",
    "ts-essentials": "^10.0.4",
    "ts-to-zod": "^3.15.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "zod-to-json-schema": "^3.24.5"
  }
}
