{
  "name": "dev-connect",
  "version": "0.0.1",
  "main": "src/index.js",
  "scripts": {
    "build": "./node_modules/.bin/webpack",
    "clean": "rm -rf dist/*",
    "serve": "./node_modules/.bin/webpack-dev-server --devtool eval --mode development --host=0.0.0.0",
    "simulator:build": "webpack --config webpack.simulator.js",
    "simulator:serve": "webpack-dev-server --config webpack.simulator.js --devtool eval --mode development --host=0.0.0.0",
    "simulator:export": "npm run simulator:build && cp dist/simulator8.js ~/repo/prod8/cdn/web-stamped/hosting/simulator8.js && echo 'Now you can send a PR to prod8.'",
    "copy": "cp dist/dev8.js ~/repo/prod8/cdn/web-stamped/hosting/dev8.js && echo 'Now you can send a PR to prod8.'",
    "postinstall": "npm run capnp:prepare; patch-package",
    "capnp:prepare": "./build-capnp-ts.sh"
  },
  "author": "Christoph Bartschat <christoph@8thwall.com>",
  "license": "ISC",
  "devDependencies": {
    "@automerge/automerge": "^2.2.0",
    "@babel/core": "^7.4.5",
    "@babel/preset-env": "^7.4.5",
    "@babel/preset-typescript": "^7.18.6",
    "babel-loader": "^8.0.6",
    "base64-js": "^1.5.1",
    "capnp-ts": "^0.2.4",
    "css-loader": "^7.1.1",
    "file-loader": "^6.2.0",
    "html-loader": "^0.5.5",
    "path-browserify": "^1.0.1",
    "process": "^0.11.10",
    "style-loader": "^4.0.0",
    "terser-webpack-plugin": "^5.3.10",
    "ts-essentials": "^9.4.1",
    "typescript": "^5.8.2",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  },
  "dependencies": {
    "error-stack-parser": "^2.0.6",
    "patch-package": "^8.0.0",
    "simple-peer": "^9.11.1",
    "source-map": "^0.7.3"
  }
}
