--- /dev/null
+++ BUILD.bazel
@@ -0,0 +1,19 @@
+cc_binary(
+    name = "shell",
+    srcs = ["shell.c"],
+    # Disable Bazel's default behavior of linking to `libstdc++` / `libc++`.
+    features = ["-default_link_libs"],
+    deps = [":sqlite3"],
+    visibility = ["//visibility:public"],
+)
+
+cc_library(
+    name = "sqlite3",
+    srcs = ["sqlite3.c"],
+    hdrs = ["sqlite3.h"],
+    # For gazelle, we are removing @platform usage, which does mean this library is only
+    # usable on platforms where pthread is available. (Not windows or android)
+    linkopts = ["-lpthread"],
+    visibility = ["//visibility:public"],
+)
+
+cc_library(
+    name = "sqlite3ext",
+    hdrs = ["sqlite3ext.h"],
+    visibility = ["//visibility:public"],
+)