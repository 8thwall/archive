{
    "compilerOptions": {
        "target": "es2020",
        "allowJs": true,
        "module": "commonjs",
        "noLib": false,
        "resolveJsonModule": true,
        "suppressImplicitAnyIndexErrors": true,
        "strict": false,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "dist/",
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
    ]
}