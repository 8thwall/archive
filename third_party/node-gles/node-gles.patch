+/* static */
+napi_value WebGLRenderingContext::GetShaderSource(napi_env env,
+                                               napi_callback_info info) {
+  LOG_CALL("GetShaderSource");
+  napi_status nstatus;
+
+  WebGLRenderingContext *context = nullptr;
+  GLuint shader;
+  nstatus = GetContextUint32Params(env, info, &context, 1, &shader);
+  ENSURE_NAPI_OK_RETVAL(env, nstatus, nullptr);
+
+  GLint source_length;
+  context->eglContextWrapper_->glGetShaderiv(shader, GL_SHADER_SOURCE_LENGTH,
+                                             &source_length);
+
+  char *error = new char[source_length];
+  context->eglContextWrapper_->glGetShaderSource(shader, source_length,
+                                                 &source_length, error);
+
+  napi_value error_value;
+  nstatus = napi_create_string_utf8(env, error, source_length, &error_value);
+  delete[] error;
+  ENSURE_NAPI_OK_RETVAL(env, nstatus, nullptr);
+
+#if DEBUG
+  context->CheckForErrors();
+#endif
+  return error_value;
+}
