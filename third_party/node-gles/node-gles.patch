+  passed: boolean = false;
+  name: string = '';
+  message: string = '';
+  object: any;
+
+  constructor() {
+  }
+
+  setPassed(passed: boolean) {
+    this.passed = passed;
+    return this;
+  }
+
+  setName(name: string) {
+    this.name = name;
+    return this;
+  }
+
+  setMessage(message: string) {
+    this.message = message;
+    return this;
+  }
+
+  setObject(...args: any[]) {
+    this.object = args;
+    return this;
+  }
