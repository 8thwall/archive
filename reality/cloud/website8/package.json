{
  "name": "website8",
  "private": true,
  "description": "The best 8th Wall website ever",
  "version": "1.0.0",
  "license": "UNLICENSED",
  "scripts": {
    "postinstall": "patch-package",
    "copySitemap": "cp public/sitemap/sitemap-0.xml public/sitemap.xml",
    "build": "gatsby build --prefix-paths && npm run copySitemap",
    "develop": "gatsby develop",
    "format": "prettier --write \"**/*.{js,jsx,json,md}\"",
    "start": "npm run develop",
    "serve": "gatsby serve",
    "clean": "gatsby clean",
    "test": "echo \"Write tests! -> https://gatsby.dev/unit-testing\" && exit 1",
    "uploadStatic": "aws s3 sync --size-only --cache-control 'public,max-age=31536000' --exclude '*' --include '*.js' --include '*.js.map' --include 'static/*' --include 'google-fonts/*' public/ s3://<REMOVED_BEFORE_OPEN_SOURCING>/static/web/",
    "uploadWebsiteStaging": "tools/upload-website-then-link.sh staging",
    "buildToStaging": "npm run build && npm run uploadStatic && npm run uploadWebsiteStaging",
    "updateStagingToProd": "tools/update-links.sh staging prod",
    "getProdInvalidations": "tools/get-invalidations.sh prod"
  },
  "dependencies": {
    "@emotion/react": "^11.10.5",
    "amazon-cognito-identity-js": "^6.1.2",
    "aws-sdk": "^2.1317.0",
    "d3-ease": "^3.0.1",
    "date-fns": "^2.29.3",
    "gatsby": "^4.24.8",
    "gatsby-image": "^2.4.5",
    "gatsby-plugin-emotion": "^7.25.0",
    "gatsby-plugin-html-attributes": "^1.0.5",
    "gatsby-plugin-jss": "^4.24.0",
    "gatsby-plugin-page-creator": "^4.24.0",
    "gatsby-plugin-react-helmet": "^5.25.0",
    "gatsby-plugin-react-i18next": "^1.2.3",
    "gatsby-plugin-robots-txt": "^1.5.3",
    "gatsby-plugin-sass": "^5.25.0",
    "gatsby-plugin-sharp": "^4.24.0",
    "gatsby-plugin-sitemap": "^5.25.0",
    "gatsby-plugin-webfonts": "^2.3.2",
    "gatsby-source-filesystem": "^4.24.0",
    "gatsby-transformer-json": "^4.24.0",
    "gatsby-transformer-remark": "^5.25.1",
    "gatsby-transformer-sharp": "^4.24.0",
    "html-react-parser": "^3.0.9",
    "i18next": "^21.10.0",
    "localforage": "^1.10.0",
    "postcss": "^8.4.21",
    "react": "^17.0.2",
    "react-circular-progressbar": "^2.1.0",
    "react-dom": "^17.0.2",
    "react-elastic-carousel": "^0.11.5",
    "react-google-recaptcha": "^2.1.0",
    "react-helmet": "^6.1.0",
    "react-hubspot-form": "^1.3.7",
    "react-i18next": "^11.18.6",
    "react-jss": "^10.10.0",
    "react-mailchimp-subscribe": "^2.1.3",
    "react-move": "^6.5.0",
    "react-twitter-embed": "^4.0.4",
    "sass": "^1.58.1",
    "styled-components": "^5.3.6"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^5.52.0",
    "@typescript-eslint/parser": "^5.52.0",
    "eslint": "^8.34.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-jsx-a11y": "^6.7.1",
    "eslint-plugin-react": "^7.32.2",
    "gatsby-plugin-asset-path": "^3.0.4",
    "gatsby-plugin-typescript": "^4.24.0",
    "md5": "^2.3.0",
    "patch-package": "^6.5.1",
    "prettier": "2.8.4",
    "typescript": "^4.9.5"
  }
}
