{
  "compilerOptions": {
    "target": "ES6",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "CommonJS",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "paths": {
      "@nia/*": [
        "../../../../*",
      ],
    },
  },
  "include": [
    "loaders/**/*.ts",
    "plugins/**/*.ts",
  ]
}
