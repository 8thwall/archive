{
  "name": "xrhome",
  "version": "1.0.1",
  "author": "Dat Chu <dat@8thwall.com>",
  "scripts": {
    "dev": "gulp",
    "dev:hot": "HOT=1 gulp",
    "console": "PORT=3001 HTTPS=true EXECUTABLE_NAME=console DEPLOYMENT_STAGE=local node server-dist/console.js",
    "watch": "PORT=3001 HTTPS=true EXECUTABLE_NAME=console DEPLOYMENT_STAGE=local nodemon --inspect server-dist/console.js --watch server-dist --delay 2",
    "apps": "NODE_OPTIONS=--enable-source-maps PORT=3030 HTTPS=true EXECUTABLE_NAME=apps DEPLOYMENT_STAGE=local node server-dist/apps.js",
    "appsw": "NODE_OPTIONS=--enable-source-maps PORT=3030 HTTPS=true EXECUTABLE_NAME=apps DEPLOYMENT_STAGE=local nodemon --inspect server-dist/apps.js --watch server-dist --delay 2",
    "dist": "NODE_OPTIONS=--max_old_space_size=8192 gulp dist",
    "start": "./run-eb.sh",
    "console:eb": "node server-dist/console.js",
    "dev:desktop": "gulp desktop",
    "dev:desktop:hot": "HOT=1 gulp desktop",
    "dist:desktop": "gulp distDesktop",
    "apps:eb": "node server-dist/apps.js",
    "clean": "gulp clean && rimraf node_modules",
    "postinstall": "patch-package",
    "deploy": "node deploy.js",
    "deploy-dev-version": "./package-deploy.sh All-dev",
    "deploy-version": "./package-deploy.sh Console-Staging deploy",
    "deploy-version-jenkins": "./package-deploy.sh Console-Staging upload",
    "eb-package": "./package-beanstalk.sh",
    "deploy-all": "echo This will distribute the most recent version to all regions.  Continue? ctrl-c to cancel && read OK && node src/server/scripts/apps-deploy.js",
    "deploy-prod": "echo This will deploy the Console-staging version.  Continue? ctrl-c to cancel && read OK && node src/server/scripts/prod-deploy.js",
    "generate-model-definitions": "npx ts-node tools/generate-model-definitions.ts > src/shared/integration/db/models.ts && npx ts-node tools/generate-client-definitions.ts > src/client/common/types/db.ts",
    "generate-studio-schema": "npx ts-node tools/generate-studio-schema.ts > src/client/studio/generated-schema.ts",
    "setup": "npm install && gulp clean",
    "test": "NODE_ENV=test ts-mocha test/**-test.* --reporter=dot",
    "test-serial": "NODE_ENV=test ts-mocha test/**-test.* --no-parallel",
    "test-file": "NODE_ENV=test ts-mocha",
    "test-file-serial": "NODE_ENV=test ts-mocha --no-parallel",
    "test-build-report": "NODE_ENV=test JUNIT_REPORT_NAME=XRhome-test JUNIT_REPORT_PATH=./test-report.xml mocha --reporter mocha-jenkins-reporter",
    "ts:check": "npx ts-node ./tools/ts/check.ts $(git merge-base HEAD main)",
    "ts:check-file": "./tools/ts/check-file.sh",
    "migrate": "node_modules/.bin/sequelize db:migrate",
    "migrate-undo": "node_modules/.bin/sequelize db:migrate:undo",
    "migrate-status": "node_modules/.bin/sequelize db:migrate:status",
    "generate-migration": "TZ=UTC npx ts-node tools/generate-migration.ts",
    "sort-translations": "find src/client/i18n/en-US -type f | grep -E \"\\.json$\" | xargs npx ts-node tools/sort-translation.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
