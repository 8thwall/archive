  "rules": [
    {
      "foreground": "#6688cc",
      "token": "meta.embedded"
    },
    {
      "foreground": "#6688cc",
      "token": "source.groovy.embedded"
    },
    {
      "foreground": "#6688cc",
      "token": "string meta.image.inline.markdown"
    },
    {
      "foreground": "#384887",
      "token": "comment"
    },
    {
      "foreground": "#22aa44",
      "token": "string"
    },
    {
      "foreground": "#f280d0",
      "token": "constant.numeric"
    },
    {
      "foreground": "#f280d0",
      "token": "constant.language"
    },
    {
      "foreground": "#f280d0",
      "token": "constant.character"
    },
    {
      "foreground": "#f280d0",
      "token": "constant.other"
    },
    {
      "fontStyle": "",
      "token": "variable"
    },
    {
      "foreground": "#225588",
      "token": "keyword"
    },
    {
      "fontStyle": "",
      "foreground": "#225588",
      "token": "storage"
    },
    {
      "fontStyle": "italic",
      "foreground": "#9966b8",
      "token": "storage.type"
    },
    {
      "fontStyle": "underline",
      "foreground": "#ffeebb",
      "token": "entity.name.class"
    },
    {
      "fontStyle": "underline",
      "foreground": "#ffeebb",
      "token": "entity.name.type"
    },
    {
      "fontStyle": "underline",
      "foreground": "#ffeebb",
      "token": "entity.name.namespace"
    },
    {
      "fontStyle": "underline",
      "foreground": "#ffeebb",
      "token": "entity.name.scope-resolution"
    },
    {
      "fontStyle": "italic underline",
      "foreground": "#ddbb88",
      "token": "entity.other.inherited-class"
    },
    {
      "fontStyle": "",
      "foreground": "#ddbb88",
      "token": "entity.name.function"
    },
    {
      "fontStyle": "italic",
      "foreground": "#2277ff",
      "token": "variable.parameter"
    },
    {
      "fontStyle": "",
      "foreground": "#225588",
      "token": "entity.name.tag"
    },
    {
      "fontStyle": "",
      "foreground": "#ddbb88",
      "token": "entity.other.attribute-name"
    },
    {
      "fontStyle": "",
      "foreground": "#9966b8",
      "token": "support.function"
    },
    {
      "fontStyle": "",
      "foreground": "#9966b8",
      "token": "support.constant"
    },
    {
      "fontStyle": "italic",
      "foreground": "#9966b8",
      "token": "support.type"
    },
    {
      "fontStyle": "italic",
      "foreground": "#9966b8",
      "token": "support.class"
    },
    {
      "fontStyle": "",
      "token": "support.other.variable"
    },
    {
      "fontStyle": "",
      "foreground": "#A22D44",
      "token": "invalid"
    },
    {
      "foreground": "#A22D44",
      "token": "invalid.deprecated"
    },
    {
      "fontStyle": "italic",
      "foreground": "#E0EDDD",
      "token": "meta.diff"
    },
    {
      "fontStyle": "italic",
      "foreground": "#E0EDDD",
      "token": "meta.diff.header"
    },
    {
      "fontStyle": "",
      "foreground": "#dc322f",
      "token": "markup.deleted"
    },
    {
      "fontStyle": "",
      "foreground": "#cb4b16",
      "token": "markup.changed"
    },
    {
      "foreground": "#219186",
      "token": "markup.inserted"
    },
    {
      "foreground": "#22aa44",
      "token": "markup.quote"
    },
    {
      "foreground": "#22aa44",
      "token": "markup.bold"
    },
    {
      "foreground": "#22aa44",
      "token": "markup.italic"
    },
    {
      "fontStyle": "bold",
      "token": "markup.bold"
    },
    {
      "fontStyle": "italic",
      "token": "markup.italic"
    },
    {
      "fontStyle": "strikethrough",
      "token": "markup.strikethrough"
    },
    {
      "fontStyle": "",
      "foreground": "#9966b8",
      "token": "markup.inline.raw"
    },
    {
      "fontStyle": "bold",
      "foreground": "#6688cc",
      "token": "markup.heading"
    },
    {
      "fontStyle": "bold",
      "foreground": "#6688cc",
      "token": "markup.heading.setext"
    }
